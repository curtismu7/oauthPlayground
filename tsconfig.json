{
	"compilerOptions": {
		"target": "ES2022",
		"useDefineForClassFields": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"skipLibCheck": true,

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,

		/* Linting */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,

		/* OAuth Security - Enhanced Type Checking */
		"strictNullChecks": true,
		"strictFunctionTypes": true,
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"noImplicitThis": true,
		"alwaysStrict": true,
		"ignoreDeprecations": "5.0",
		"downlevelIteration": true,

		/* Path mapping */
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"@/components/*": ["src/components/*"],
			"@/pages/*": ["src/pages/*"],
			"@/utils/*": ["src/utils/*"],
			"@/contexts/*": ["src/contexts/*"],
			"@/styles/*": ["src/styles/*"],
			"@/mfa/*": ["src/mfa/*"],
			"@/mfa/components/*": ["src/mfa/components/*"],
			"@/mfa/services/*": ["src/mfa/services/*"],
			"@/mfa/hooks/*": ["src/mfa/hooks/*"],
			"@/mfa/flows/*": ["src/mfa/flows/*"],
			"@/mfa/types/*": ["src/mfa/types/*"],
			"@/mfa/utils/*": ["src/mfa/utils/*"],
			"@icons": ["src/icons/index.ts"]
		},

		/* Additional type checking for security */
		"exactOptionalPropertyTypes": true,
		"noImplicitOverride": true,
		"noPropertyAccessFromIndexSignature": false,
		"noUncheckedIndexedAccess": false
	},
	"include": ["src"],
	"exclude": [
		"node_modules",
		"backups",
		"dist",
		"src/locked",
		"src/pages/flows/_backup",
		"src/**/lockdown/**",
		"src/**/snapshot/**",
		"src/pages/flows/archived/**",
		"src/samples/**",
		"src/templates/**",
		"src/examples/**"
	],
	"references": [{ "path": "./tsconfig.node.json" }]
}
