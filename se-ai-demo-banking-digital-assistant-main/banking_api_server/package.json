{
  "name": "banking-api-server",
  "version": "1.0.0",
  "description": "Simple banking API server with admin UI",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --config=jest.integration.config.js",
    "test:oauth": "./run-oauth-integration-tests.sh",
    "test:oauth-scope": "jest --testPathPattern=oauth-scope-integration.test.js --verbose --forceExit",
    "test:oauth-e2e": "jest --testPathPattern=oauth-e2e-integration.test.js --verbose --forceExit",
    "test:coverage": "jest --coverage --config=jest.integration.config.js",
    "test:scope-assignments": "node test-scope-assignments.js",
    "test:oauth-provider-scopes": "node test-oauth-provider-scopes.js",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "heroku-postbuild": "npm run install-client && npm run build"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4"
  },
  "keywords": [
    "banking",
    "api",
    "rest",
    "express"
  ],
  "author": "",
  "license": "MIT"
}
