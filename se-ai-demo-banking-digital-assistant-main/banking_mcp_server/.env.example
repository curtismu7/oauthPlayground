# Banking MCP Server Configuration Example
# Copy this file to .env.development or .env.production and update with your values

# =============================================================================
# ENVIRONMENT SETTINGS
# =============================================================================
NODE_ENV=development
LOG_LEVEL=INFO

# =============================================================================
# MCP SERVER CONFIGURATION
# =============================================================================
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8080
MCP_SERVER_MAX_CONNECTIONS=100
MCP_SERVER_SESSION_TIMEOUT=3600

# =============================================================================
# PINGONE ADVANCED IDENTITY CLOUD CONFIGURATION (REQUIRED)
# =============================================================================
# Get these values from your PingOne Advanced Identity Cloud environment
PINGONE_BASE_URL=https://your-environment.pingidentity.com
PINGONE_CLIENT_ID=your-client-id
PINGONE_CLIENT_SECRET=your-client-secret
PINGONE_INTROSPECTION_ENDPOINT=https://your-environment.pingidentity.com/as/introspect
PINGONE_AUTHORIZATION_ENDPOINT=https://your-environment.pingidentity.com/as/authorize
PINGONE_TOKEN_ENDPOINT=https://your-environment.pingidentity.com/as/token

# =============================================================================
# BANKING API CONFIGURATION
# =============================================================================
BANKING_API_BASE_URL=http://localhost:3001
BANKING_API_TIMEOUT=30000
BANKING_API_MAX_RETRIES=3
BANKING_API_CIRCUIT_BREAKER_THRESHOLD=5

# =============================================================================
# SECURITY CONFIGURATION (REQUIRED)
# =============================================================================
# Generate a secure 64+ character encryption key
# You can use: openssl rand -base64 48
ENCRYPTION_KEY=your-64-character-encryption-key-here-replace-with-secure-key

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================
TOKEN_STORAGE_PATH=./data/tokens
SESSION_STORAGE_PATH=./data/sessions
TOKEN_CACHE_TTL_SECONDS=3600
SESSION_CLEANUP_INTERVAL_SECONDS=300

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
AUDIT_LOG_PATH=./logs/audit.log
SECURITY_LOG_PATH=./logs/security.log
ENABLE_DETAILED_LOGGING=false

# =============================================================================
# DEVELOPMENT SETTINGS (Development environment only)
# =============================================================================
# Uncomment for development
# ENABLE_DEBUG_MODE=true
# SKIP_SSL_VERIFICATION=true
# MOCK_BANKING_API=false

# =============================================================================
# PRODUCTION SETTINGS (Production environment only)
# =============================================================================
# Uncomment for production
# ENABLE_RATE_LIMITING=true
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# ENABLE_CORS=false
# CORS_ALLOWED_ORIGINS=https://your-frontend.com

# =============================================================================
# MONITORING AND HEALTH CHECKS
# =============================================================================
HEALTH_CHECK_INTERVAL_SECONDS=30
ENABLE_METRICS=true
METRICS_PORT=9090

# =============================================================================
# DOCKER CONFIGURATION (Docker deployments only)
# =============================================================================
# Uncomment for Docker
# DOCKER_INTERNAL_PORT=8080
# DOCKER_DATA_VOLUME=/app/data
# DOCKER_LOGS_VOLUME=/app/logs