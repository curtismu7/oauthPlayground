{
  "name": "banking-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for banking operations",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:clean": "rm -rf dist && npm run build",
    "build:prod": "NODE_ENV=production npm run build:clean",
    "dev": "NODE_ENV=development nodemon --exec ts-node src/index.ts",
    "dev:debug": "NODE_ENV=development nodemon --inspect --exec ts-node src/index.ts",
    "start": "NODE_ENV=production node dist/index.js",
    "start:dev": "NODE_ENV=development node dist/index.js",
    "start:staging": "NODE_ENV=staging node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "test": "NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "test:ci": "NODE_ENV=test jest --ci --coverage --watchAll=false",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run test:ci",
    "prestart": "npm run build",
    "prestart:prod": "npm run build:prod",
    "health-check": "node scripts/health-check.js",
    "config:validate": "node scripts/validate-config.js",
    "config:example": "node scripts/create-example-config.js",
    "docker:build": "docker build -t banking-mcp-server .",
    "docker:run": "docker run -p 8080:8080 --env-file .env banking-mcp-server",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d"
  },
  "keywords": [
    "mcp",
    "banking",
    "server"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "nodemon": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "axios": "^1.6.0",
    "dotenv": "^17.2.2",
    "jsonschema": "^1.4.1",
    "uuid": "^9.0.0",
    "ws": "^8.14.0"
  }
}
