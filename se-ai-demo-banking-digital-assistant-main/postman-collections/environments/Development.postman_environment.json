{
  "id": "dev-banking-api-environment",
  "name": "Banking API - Development",
  "values": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "description": "Base URL for the Banking API server",
      "enabled": true
    },
    {
      "key": "oauth_base_url",
      "value": "https://auth.pingone.com",
      "description": "PingOne OAuth provider base URL",
      "enabled": true
    },
    {
      "key": "oauth_tenant",
      "value": "{{p1aic_tenant_name}}",
      "description": "PingOne tenant name - replace with your tenant",
      "enabled": true
    },
    {
      "key": "oauth_environment_id",
      "value": "{{p1aic_environment_id}}",
      "description": "PingOne environment ID - replace with your environment ID",
      "enabled": true
    },
    {
      "key": "admin_client_id",
      "value": "{{admin_client_id}}",
      "description": "OAuth client ID for admin user authentication",
      "enabled": true
    },
    {
      "key": "admin_client_secret",
      "value": "{{admin_client_secret}}",
      "description": "OAuth client secret for admin user authentication",
      "enabled": true
    },
    {
      "key": "user_client_id",
      "value": "{{user_client_id}}",
      "description": "OAuth client ID for end user authentication",
      "enabled": true
    },
    {
      "key": "user_client_secret",
      "value": "{{user_client_secret}}",
      "description": "OAuth client secret for end user authentication",
      "enabled": true
    },
    {
      "key": "redirect_uri",
      "value": "http://localhost:3000/oauth/callback",
      "description": "OAuth redirect URI for development",
      "enabled": true
    },
    {
      "key": "admin_scopes",
      "value": "banking:admin openid profile email",
      "description": "OAuth scopes for admin user",
      "enabled": true
    },
    {
      "key": "user_scopes",
      "value": "banking:read banking:write openid profile email",
      "description": "OAuth scopes for end user",
      "enabled": true
    },
    {
      "key": "access_token",
      "value": "",
      "description": "Current OAuth access token (auto-populated)",
      "enabled": true
    },
    {
      "key": "refresh_token",
      "value": "",
      "description": "Current OAuth refresh token (auto-populated)",
      "enabled": true
    },
    {
      "key": "token_expires_at",
      "value": "",
      "description": "Token expiration timestamp (auto-populated)",
      "enabled": true
    },
    {
      "key": "token_type",
      "value": "Bearer",
      "description": "OAuth token type",
      "enabled": true
    },
    {
      "key": "user_id",
      "value": "",
      "description": "Current authenticated user ID (auto-populated)",
      "enabled": true
    },
    {
      "key": "account_id",
      "value": "",
      "description": "Test account ID for transaction operations (auto-populated)",
      "enabled": true
    },
    {
      "key": "transaction_id",
      "value": "",
      "description": "Test transaction ID for detail operations (auto-populated)",
      "enabled": true
    },
    {
      "key": "unique_id",
      "value": "",
      "description": "Unique identifier for test data generation (auto-populated)",
      "enabled": true
    },
    {
      "key": "test_email",
      "value": "",
      "description": "Generated test email address (auto-populated)",
      "enabled": true
    },
    {
      "key": "code_verifier",
      "value": "",
      "description": "PKCE code verifier (auto-generated)",
      "enabled": true
    },
    {
      "key": "code_challenge",
      "value": "",
      "description": "PKCE code challenge (auto-generated)",
      "enabled": true
    },
    {
      "key": "state",
      "value": "",
      "description": "OAuth state parameter (auto-generated)",
      "enabled": true
    }
  ],
  "_postman_variable_scope": "environment"
}