{
  "id": "prod-banking-api-environment",
  "name": "Banking API - Production",
  "values": [
    {
      "key": "base_url",
      "value": "https://api.bankingapi.com",
      "description": "Base URL for the Banking API production server",
      "enabled": true
    },
    {
      "key": "oauth_base_url",
      "value": "https://auth.pingone.com",
