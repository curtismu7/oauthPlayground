# Server Configuration
PORT=3002
NODE_ENV=development

# OAuth Configuration
OAUTH_ISSUER_URL=https://auth.pingone.com/your-environment-id/as
OAUTH_CLIENT_ID=your_lending_client_id
OAUTH_CLIENT_SECRET=your_lending_client_secret

# Security
SESSION_SECRET=your_secure_session_secret_here
ENCRYPTION_KEY=your_32_character_encryption_key

# Lending Service Configuration
CREDIT_SCORE_TTL=3600
DEFAULT_CREDIT_LIMIT=5000
MINIMUM_CREDIT_SCORE=600
MAX_CREDIT_LIMIT=50000

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Database (Future Enhancement)
# DATABASE_URL=postgresql://user:password@localhost:5432/lending_db

# External Services (Future Enhancement)
# CREDIT_BUREAU_API_URL=https://api.creditbureau.com
# CREDIT_BUREAU_API_KEY=your_api_key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3003