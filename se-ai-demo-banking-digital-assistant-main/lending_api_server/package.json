{
  "name": "lending-api-server",
  "version": "1.0.0",
  "description": "Consumer lending API server with OAuth authentication",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --config=jest.integration.config.js",
    "test:oauth": "./run-oauth-integration-tests.sh",
    "test:oauth-scope": "jest --testPathPattern=oauth-scope-integration.test.js --verbose --forceExit",
    "test:oauth-e2e": "jest --testPathPattern=oauth-e2e-integration.test.js --verbose --forceExit",
    "test:coverage": "jest --coverage --config=jest.integration.config.js",
    "test:scope-assignments": "node test-scope-assignments.js",
    "test:oauth-provider-scopes": "node test-oauth-provider-scopes.js",
    "test:comprehensive": "node src/__tests__/run-comprehensive-tests.js",
    "test:business-logic": "jest --testPathPattern=business-logic.test.js --verbose",
    "test:oauth-auth": "jest --testPathPattern=oauth-authentication.test.js --verbose",
    "test:scope-validation": "jest --testPathPattern=api-endpoints-scope-validation.test.js --verbose",
    "test:error-handling": "jest --testPathPattern=error-handling-edge-cases.test.js --verbose",
    "test:workflows": "jest --testPathPattern=integration-workflows.test.js --verbose",
    "test:e2e": "jest --config=jest.e2e.config.js",
    "test:e2e-runner": "node src/__tests__/e2e/run-e2e-tests.js",
    "test:e2e-user-workflows": "jest --config=jest.e2e.config.js --testPathPattern=user-workflows.test.js",
    "test:e2e-cross-service": "jest --config=jest.e2e.config.js --testPathPattern=cross-service-communication.test.js",
    "test:e2e-performance": "jest --config=jest.e2e.config.js --testPathPattern=performance-load.test.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "jsonwebtoken": "^9.0.2",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4"
  },
  "keywords": [
    "lending",
    "api",
    "rest",
    "express",
    "credit",
    "oauth"
  ],
  "author": "",
  "license": "MIT"
}
