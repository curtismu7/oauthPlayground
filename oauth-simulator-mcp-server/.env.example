# OAuth Flow Simulator Configuration
LOG_LEVEL=info

# Optional: Default issuer URL for token validation
DEFAULT_ISSUER_URL=https://auth.example.com

# PKCE Configuration
PKCE_VERIFIER_MIN_LENGTH=43
PKCE_VERIFIER_MAX_LENGTH=128
PKCE_CHALLENGE_METHOD=S256

# Simulator settings
ENABLE_EDUCATIONAL_MODE=true
INCLUDE_RFC_REFERENCES=true
