        <!-- Browser → PingOne (redirect flows) -->
        <mxCell id="arrow-fe-pingone" value="Browser redirect&#xa;(authz code flow)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=1;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;fontSize=10;strokeColor=#2196F3;strokeWidth=1.5;dashed=1;" edge="1" parent="1" source="fe-bg" target="ext-bg">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="850" y="230" />
              <mxPoint x="850" y="294" />
              <mxPoint x="1360" y="294" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend-bg" value="Legend" style="swimlane;startSize=22;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1360" y="785" width="270" height="130" as="geometry" />
        </mxCell>
        <mxCell id="leg1" value="OAuth / OIDC Flow (v9)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1370" y="815" width="240" height="25" as="geometry" />
        </mxCell>
        <mxCell id="leg2" value="Express API Route / Serverless Fn" style="rounded=1;fillColor=#f8bbd0;strokeColor=#e91e63;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1370" y="848" width="240" height="25" as="geometry" />
        </mxCell>
        <mxCell id="leg3" value="PingOne / External Service" style="rounded=1;fillColor=#c8e6c9;strokeColor=#388e3c;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1370" y="881" width="240" height="25" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <!-- ===== SECOND DIAGRAM: TOKEN EXCHANGE RFC 8693 FLOW ===== -->
  <diagram id="token-exchange-flow" name="Token Exchange RFC 8693 Flow">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t-title" value="RFC 8693 Token Exchange — may_act Validation Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="970" height="35" as="geometry" />
        </mxCell>

        <!-- Actors -->
        <mxCell id="actor-client" value="Client App&#xa;(Browser / API Consumer)" style="shape=mxgraph.flowchart.start_2;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="90" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="actor-be" value="api/token-exchange.js&#xa;(Vercel / Express)" style="shape=mxgraph.flowchart.process;fillColor=#f8bbd0;strokeColor=#e91e63;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="90" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="actor-po" value="PingOne&#xa;/as/token" style="shape=mxgraph.flowchart.start_2;fillColor=#c8e6c9;strokeColor=#388e3c;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="90" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Step boxes -->
        <mxCell id="s1" value="1. POST /api/token-exchange&#xa;{ subject_token, actor_token,&#xa;  grant_type: token-exchange }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="185" width="240" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="2. Decode subject_token JWT&#xa;Extract may_act claim" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="410" y="285" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s3-check" value="may_act present&#xa;and is plain object?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="410" y="360" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s3-no" value="403 delegation_not_permitted&#xa;400 invalid_may_act" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#e57373;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="370" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="3. Decode actor_token JWT&#xa;Extract: client_id / azp, sub, iss" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="410" y="455" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s5-and" value="AND match all fields&#xa;in may_act vs actor?&#xa;(no wildcards)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="410" y="530" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s5-no" value="403 actor_mismatch&#xa;400 unsupported_may_act" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#e57373;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="555" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="4. Forward to PingOne&#xa;/as/token with actor_token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#388e3c;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="590" y="640" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="5. Inject act claim&#xa;{ client_id, sub } into response" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#388e3c;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="410" y="640" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="6. Return token + act to client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="715" width="200" height="40" as="geometry" />
        </mxCell>

        <!-- Arrows -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="1" source="actor-client" target="s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="1" source="s2" target="s3-check">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a3-no" value="No" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;strokeColor=#e57373;" edge="1" parent="1" source="s3-check" target="s3-no">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a3-yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="1" source="s3-check" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="1" source="s4" target="s5-and">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a5-no" value="No" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;strokeColor=#e57373;" edge="1" parent="1" source="s5-and" target="s5-no">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a5-yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="1" source="s5-and" target="s6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="1" source="s6" target="actor-po">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="1" source="s6" target="s7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a8" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="1" source="s7" target="s8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a9" style="edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="1" source="s8" target="actor-client">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
