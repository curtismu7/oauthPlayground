<html>
<head>
<meta charset="utf-8" />
</head>
<body>
<table border="1">
  <thead>
    <tr>
      <th>Service</th>
      <th>Apps/Components</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td>UnifiedMFARegistrationFlow</td>
      <td>UnifiedConfigurationStep; UnifiedDeviceSelectionStep; UnifiedRegistrationStep; UnifiedSuccessStep; SearchableDropdown; MFACredentialContext; GlobalMFAContext</td>
    </tr>
    <tr>
      <td>mfaService</td>
      <td>UnifiedMFARegistrationFlow; UnifiedConfigurationStep; server proxy endpoints (/api/pingone/mfa/*); other MFA flows</td>
    </tr>
    <tr>
      <td>tokenGateway</td>
      <td>WorkerTokenModal; workerTokenUIService; workerTokenModalHelper; any token requesters</td>
    </tr>
    <tr>
      <td>unifiedWorkerTokenService</td>
      <td>WorkerTokenModal; workerTokenRepository; workerTokenBackupService; workerTokenCacheService; workerTokenUIService</td>
    </tr>
    <tr>
      <td>WorkerTokenStatusService</td>
      <td>WorkerTokenModal; workerTokenUIService; workerTokenCacheService</td>
    </tr>
    <tr>
      <td>workerTokenCacheService</td>
      <td>WorkerTokenModal (preflight); tokenGateway helpers</td>
    </tr>
    <tr>
      <td>workerTokenRepository</td>
      <td>unifiedWorkerTokenService; workerTokenBackupService</td>
    </tr>
    <tr>
      <td>MFAConfigurationService</td>
      <td>workerTokenModalHelper; WorkerTokenModal; UI checkboxes</td>
    </tr>
    <tr>
      <td>pingOneFetch</td>
      <td>mfaService; many v8 services (backend calls); integrates with backendConnectivityService</td>
    </tr>
    <tr>
      <td>backendConnectivityService</td>
      <td>pingOneFetch; mfaService; BackendDownModal; App.tsx (global modal)</td>
    </tr>
    <tr>
      <td>BackendDownModal</td>
      <td>App.tsx (global); subscribed components via backendConnectivityService</td>
    </tr>
    <tr>
      <td>MFAFlowController</td>
      <td>Shared orchestration used by unified and other MFA flows</td>
    </tr>
    <tr>
      <td>MFACredentialContext</td>
      <td>UnifiedMFARegistrationFlow and subcomponents</td>
    </tr>
    <tr>
      <td>GlobalMFAContext</td>
      <td>UnifiedMFARegistrationFlow and cross-component state</td>
    </tr>
    <tr>
      <td>preFlightValidationService</td>
      <td>WorkerTokenModal (validates OAuth config)</td>
    </tr>
    <tr>
      <td>unifiedMFASuccessPageService</td>
      <td>UnifiedSuccessStep; legacy flows mapping to unified success</td>
    </tr>
    <tr>
      <td>SearchableDropdown</td>
      <td>UnifiedMFARegistrationFlow (user lookup)</td>
    </tr>
    <tr>
      <td>toast</td>
      <td>Many UI components (WorkerTokenModal, UnifiedMFARegistrationFlow, services)</td>
    </tr>
    <tr>
      <td>server.js proxy endpoints</td>
      <td>UI callers via mfaService and other client services</td>
    </tr>
  </tbody>
</table>
</body>
</html>