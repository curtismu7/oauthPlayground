# oauth-oidc-mcp-server — provider-agnostic OAuth/OIDC flow tools.
#
# This server is provider-agnostic. Endpoints are resolved in priority order:
#   1. Explicit per-call endpoint params on the tool
#   2. OIDC discovery from an `issuerUrl` (.well-known/openid-configuration)
#   3. PingOne preset: environmentId + region -> auth.pingone.{region}/{envId}/as/*
#   4. These environment-variable defaults
#
# All values below are OPTIONAL defaults — every tool accepts per-call overrides.

# ---- Default issuer (any OIDC provider) ----
# If set, tools without explicit endpoints will run discovery against this issuer.
OAUTH_ISSUER_URL=

# ---- PingOne convenience preset ----
# When set (and no issuer/endpoints given), endpoints are computed as
#   https://auth.pingone.{PINGONE_REGION}/{PINGONE_ENVIRONMENT_ID}/as/{token|authorize|jwks|userinfo|...}
PINGONE_ENVIRONMENT_ID=
# Region suffix: com (US, default) | eu | ca | asia
PINGONE_REGION=com

# ---- Default client credentials (optional) ----
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# Token-endpoint client auth: client_secret_basic | client_secret_post | none
OAUTH_CLIENT_AUTH_METHOD=client_secret_post

# ---- Default scope ----
OAUTH_DEFAULT_SCOPE=openid profile email

# ---- Logging ----
MCP_LOG_DIR=logs
