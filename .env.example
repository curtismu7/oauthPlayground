# Application Configuration
VITE_APP_TITLE="PingOne OAuth Playground"
VITE_APP_DESCRIPTION="Interactive playground for OAuth 2.0 and OpenID Connect with PingOne"
VITE_APP_VERSION="2.0.0"
VITE_APP_DEFAULT_THEME="light"

# PingOne Configuration - Replace with your actual values
VITE_PINGONE_ENVIRONMENT_ID=b9817c16-9910-4415-b67e-4ac687da74d9
VITE_PINGONE_CLIENT_ID=26e7f07c-11a4-402a-b064-07b55aee189e
VITE_PINGONE_CLIENT_SECRET=9p3hLItWFzw5BxKjH3.~TIGVPP~uj4os6fY93170dMvXadn1GEsWTP2lHSTAoevq
VITE_PINGONE_REDIRECT_URI=http://localhost:8000/callback
VITE_PINGONE_LOGOUT_REDIRECT_URI=http://localhost:8000
VITE_PINGONE_API_URL=https://auth.pingone.com
VITE_PINGONE_AUTH_SERVER_ID=your-auth-server-id

# Development Settings
VITE_DEV_SERVER_PORT=8000
VITE_DEV_SERVER_HTTPS=false
# Set to 1 when using a custom domain (e.g. api.pingdemo.com) to avoid HMR WebSocket errors in the console
# VITE_DISABLE_HMR=1

# Feature Flags
VITE_FEATURE_DEBUG_MODE=false
VITE_FEATURE_ANALYTICS=false

# AI Assistant web search (optional). Get a key at https://brave.com/search/api/
# When set, the "Web" toggle in the AI Assistant includes live search results.
# BRAVE_API_KEY=your_brave_api_key_here

# ─── AI Assistant LLM provider ───────────────────────────────────────────────
# AI_PROVIDER: auto (default) | llama.cpp | groq | openai | anthropic (planned)
# auto resolution order: llama.cpp (local) → Groq (legacy). Does NOT infer OpenAI cloud from OPENAI_API_KEY.
AI_PROVIDER=auto

# llama.cpp local server (OpenAI-compatible). Start llama-server separately.
# Default base URL matches llama.cpp --port 8080 with /v1 prefix.
LLAMA_CPP_BASE_URL=http://localhost:8080/v1
# Model name sent in chat/completions (match your loaded GGUF or use any string)
LLAMA_CPP_MODEL=local
# Optional bearer for llama.cpp (if your server requires auth). Falls back to OPENAI_API_KEY below.
# LLAMA_CPP_API_KEY=your_llama_cpp_bearer_token

# Bearer token for llama.cpp OpenAI-compatible server (NOT OpenAI cloud unless AI_PROVIDER=openai).
# Many llama.cpp setups use any string or the key configured on llama-server.
# OPENAI_API_KEY=your_llama_cpp_bearer_token

# OpenAI cloud (only when AI_PROVIDER=openai). Get a key at https://platform.openai.com/api-keys
# Uses the same OPENAI_API_KEY var — set AI_PROVIDER=openai explicitly to call api.openai.com.
OPENAI_MODEL=gpt-4o-mini

# Anthropic Messages API (planned — AI_PROVIDER=anthropic not yet implemented)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq LLM (legacy fallback). Set AI_PROVIDER=groq or rely on auto when llama.cpp is unavailable.
# GROQ_API_KEY=your_groq_api_key_here
